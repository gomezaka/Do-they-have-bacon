# Copy this file to .env.local and fill in your own secret values.
# Do not commit .env.local.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DATA_MODE=local

# Enables R2 upload testing even when the app uses localStorage as the data layer.
NEXT_PUBLIC_ENABLE_R2_UPLOADS=true
BACON_ALLOW_LOCAL_R2_UPLOADS=true

# Cloudflare R2
R2_ACCOUNT_ID=replace-with-the-account-id-from-your-r2-endpoint
R2_ACCESS_KEY_ID=replace-with-your-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-your-r2-secret-access-key
R2_BUCKET_NAME=do-they-have-bacon

# This is NOT the S3 endpoint. Use the public bucket/custom domain/r2.dev URL.
R2_PUBLIC_URL=replace-with-your-public-r2-url

# Optional for later
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
BACON_ENABLE_TURNSTILE=false
