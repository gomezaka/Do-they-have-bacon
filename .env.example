# App
# Local dev:
# AUTH REDIRECT NOTE: for deployed auth, Supabase URL Configuration must include the public /auth/callback URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example after Cloudflare deploy:
# NEXT_PUBLIC_APP_URL=https://your-worker-url.workers.dev

# Data mode
# local = browser localStorage only. Best for first testing.
# supabase = use the API routes in this project and your Supabase database.
NEXT_PUBLIC_DATA_MODE=local

# Supabase
# Required only when NEXT_PUBLIC_DATA_MODE=supabase.
# Users do not need to sign in; v0.9 is anonymous-first.
NEXT_PUBLIC_SUPABASE_URL=https://qivsimkychjsknuhhfff.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this in client code or commit .env.local.
# Required for the project API routes when NEXT_PUBLIC_DATA_MODE=supabase.
SUPABASE_SERVICE_ROLE_KEY=

# Free open map geocoding.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Cloudflare Turnstile spam protection.
# Optional. When BACON_ENABLE_TURNSTILE=true, hotel/report API routes require a valid token.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
BACON_ENABLE_TURNSTILE=false

# Cloudflare R2 photo evidence storage.
# Optional. When all values exist and NEXT_PUBLIC_ENABLE_R2_UPLOADS=true,
# photo evidence can be uploaded to R2 using a signed PUT URL.
R2_ACCOUNT_ID=5f44dac9f8c098cf64000b4f4a80efe4
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=do-they-have-bacon
R2_PUBLIC_URL=https://pub-2e03acbe4ae14fbea6b571d7cd8425cb.r2.dev

# R2 upload behavior
# Local R2 testing with localStorage:
# NEXT_PUBLIC_ENABLE_R2_UPLOADS=true
# BACON_ALLOW_LOCAL_R2_UPLOADS=true
#
# Real public deployment:
# NEXT_PUBLIC_ENABLE_R2_UPLOADS=true
# BACON_ALLOW_LOCAL_R2_UPLOADS=false
NEXT_PUBLIC_ENABLE_R2_UPLOADS=false
BACON_ALLOW_LOCAL_R2_UPLOADS=false

# Optional. Keep false/blank in public beta. Set true locally only when you need /dev.
NEXT_PUBLIC_SHOW_DEV_TOOLS=false
